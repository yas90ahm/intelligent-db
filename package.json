{
  "name": "intelligent-db",
  "version": "0.0.0",
  "private": true,
  "description": "A memory substrate for AI agents: latent memory surfaced by spreading activation, with first-class provenance and an external source-identity layer.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yas90ahm/intelligent-db.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "intelligent-db-mcp": "dist/mcp/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "demo": "npm run build && node dist/examples/demo.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "bench": "vitest bench --run",
    "mcp": "node dist/mcp/server.js"
  },
  "devDependencies": {
    "@duckdb/node-api": "^1.5.4-r.1",
    "@huggingface/transformers": "^4.2.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "@types/node": "^22.10.0",
    "better-sqlite3": "^12.11.1",
    "lmdb": "^3.5.6",
    "pg": "^8.22.0",
    "redis": "^6.0.1",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
