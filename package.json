{
  "name": "intelligent-db",
  "version": "0.0.0",
  "private": true,
  "description": "A memory substrate for AI agents: latent memory surfaced by spreading activation, with first-class provenance and an external source-identity layer.",
  "keywords": [
    "ai-agents",
    "memory",
    "agent-memory",
    "knowledge-graph",
    "provenance",
    "spreading-activation",
    "mcp",
    "model-context-protocol",
    "anti-poisoning",
    "sybil-resistance",
    "trust-registry",
    "rag-alternative",
    "sqlite",
    "typescript"
  ],
  "license": "Apache-2.0",
  "author": "Yasir <1290yasir@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yas90ahm/intelligent-db.git"
  },
  "homepage": "https://github.com/yas90ahm/intelligent-db#readme",
  "bugs": {
    "url": "https://github.com/yas90ahm/intelligent-db/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "bin": {
    "intelligent-db-mcp": "dist/mcp/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "demo": "npm run build && node dist/examples/demo.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "bench": "vitest bench --run",
    "mcp": "node dist/mcp/server.js",
    "torture:build": "tsc -p tsconfig.torture.json",
    "torture": "npm run torture:build && node node_modules/.torture-build/__torture__/runTorture.js",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@duckdb/node-api": "^1.5.4-r.1",
    "@huggingface/transformers": "^4.2.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "@types/node": "^22.10.0",
    "better-sqlite3": "^12.11.1",
    "faiss-node": "^0.5.1",
    "hnswlib-node": "^3.0.0",
    "lmdb": "^3.5.6",
    "pg": "^8.22.0",
    "redis": "^6.0.1",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
